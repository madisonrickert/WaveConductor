{
  "extends": ["eslint:recommended"],
  "rules": {
    "max-len": "off",
    "sort-keys": "off",
    "object-shorthand": "off",
    "no-console": "off",
    "no-debugger": "off",
    "no-empty": "off",
    "no-bitwise": "off",
    "no-unused-vars": "warn",
    "prefer-const": "off",
    "no-var": "off",
    "no-redeclare": "off",
    "no-prototype-builtins": "off",
    "no-useless-escape": "off",
    "quotes": "off",
    "semi": "off",
    "no-restricted-syntax": "off",
    "no-undef": "off"
  },
  "parserOptions": {
    "ecmaVersion": 2020,
    "sourceType": "module"
  },
  "env": {
    "browser": true,
    "node": true,
    "es6": true
  }
}
