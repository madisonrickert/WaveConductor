# Ensure consistent line endings for all text files
* text=auto

# Treat common binary file types as binary (no diff or merge)
*.jpg binary
*.jpeg binary
*.png binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.gz binary
*.tar binary
*.mp4 binary
*.mp3 binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.pkg binary
*.exe binary
*.dll binary

# Normalize line endings for source code
*.js text eol=lf
*.jsx text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.mjs text eol=lf
*.json text eol=lf
*.html text eol=lf
*.css text eol=lf
*.scss text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.xml text eol=lf

# Handle shell scripts properly on Linux/macOS
*.sh text eol=lf

# Handle batch scripts properly on Windows
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Node.js specific
*.env text eol=lf
.npmrc text eol=lf
.nvmrc text eol=lf
.yarnrc text eol=lf
*.lock text eol=lf

# Exclude minified files from diff
*.min.js -diff
*.min.css -diff

# Editor config and tooling
.editorconfig text eol=lf
